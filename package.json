    "license": "MIT",
    "bugs": {
        "url": "https://github.com/bertman12/wc3-w3ts-frame-components/issues"
    },
    "homepage": "https://github.com/bertman12/wc3-w3ts-frame-components#readme",
    "dependencies": {
        "war3-types-strict": "^0.1.3",
        "warcraft-3-w3ts-utils": "^0.1.40"
    },
    "devDependencies": {
        "lua-types": "^2.13.1",
        "typescript-to-lua": "1.31.0",
        "war3-objectdata-th": "^0.2.11",
        "war3-transformer": "^3.0.10",
        "war3tstlhelper": "1.0.1"
    },
    "peerDependencies": {
        "lua-types": "^2.13.1",
